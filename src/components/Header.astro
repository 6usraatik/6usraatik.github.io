---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Ana Sayfa</HeaderLink>
			<HeaderLink href="/blog">Projelerim</HeaderLink>
			<HeaderLink href="/about">Hakkımda</HeaderLink>
		</div>
	</nav>
</header>
<style>
  /* ==========================================================================
     1. GOOGLE FONTS - Doğadan İlham Alan Editoryal Fontlar (Fraunces & Lora)
     ========================================================================== */
  @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=Caveat:wght@600;700&display=swap');
  /* ==========================================================================
     2. ÜST MENÜ (HEADER) - Buzlu Cam Efekti, Doğal Tonlar ve Akıcı Geçişler
     ========================================================================== */
  header {
    margin: 0;
    padding: 0 1.5em;
    /* Çiğ beyaz yerine yarı şeffaf sıcak kemik/bej tonu ve buzlu cam bulantısı */
    background: rgba(247, 245, 240, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    
    /* Sert siyah gölge yerine alt kısma çok hafif, sıcak bir kum ayırıcı çizgi */
    border-bottom: 1px solid rgba(220, 214, 205, 0.6);
    box-shadow: 0 4px 20px -10px rgba(115, 102, 90, 0.05);
    
    /* Sayfa kaydırıldığında menünün üstte şıkça asılı kalması için */
    position: sticky;
    top: 0;
    z-index: 1000;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ==========================================================================
     3. NAVİGASYON VE DÜZEN (Modern Mizanpaj)
     ========================================================================== */
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1100px;
    margin: 0 auto;
    height: 70px; /* Menüye ferah ve editoryal bir yükseklik kazandırdık */
  }

  /* ==========================================================================
     4. LOGO / SİTE BAŞLIĞI - Botanik Dokunuş (Fraunces Fontu & İtalik Selamlama)
     ========================================================================== */
  h2 {
    margin: 0;
    font-size: 1.35em; /* Organik serif fontlar biraz daha dolgun durunca harika görünür */
    font-weight: 700;
    letter-spacing: -0.01em;
    font-family: 'Fraunces', serif; /* Doğal kıvrımlı, botanik fontu tanımladık */
  }

  header h2 {
    display: none; /* Bu satır görselde ismi gizler */
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
    color: #2c2926; /* Derin espresso kahvesi */
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-block;
  }

  /* Üzerine gelindiğinde adaçayı yeşiline dönüp hafifçe sağa yatarak selamlama yapması */
  h2 a:hover {
    color: #597a61;
    font-style: italic;
    transform: translateX(2px);
  }

  /* ==========================================================================
     5. MENÜ LİNK ETİKETLERİ (Organik Etkileşim ve Pastel Vurgular)
     ========================================================================== */
  nav a {
    padding: 0.5em 0.8em;
    margin: 0 0.2em;
    color: #645f5b; /* Yumuşak toprak/kahve-gri */
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95em;
    border-radius: 8px; /* Kalın alt çizgiler yerine modern, yumuşak kutucuklar */
    transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
  }

  /* Linklerin üzerine gelindiğinde çok hafif pastel bir kum zemini oluşması */
  nav a:hover {
    color: #2c2926;
    background-color: rgba(220, 214, 205, 0.3);
    transform: translateY(-1px);
  }

  /* Aktif Sayfa Linki (Şu an bulunulan sayfa) */
  nav a.active {
    color: #2c2926;
    font-weight: 600;
    background-color: #f5f2eb; /* Sıcak kum tonu */
  }

  /* Aktif sayfayı belirten çok zarif, adaçayı yeşili alt nokta deseni */
  nav a.active::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    background-color: #597a61; /* Adaçayı yeşili vurgu */
    border-radius: 50%;
  }

  /* ==========================================================================
     6. KARANLIK MOD (Dark Mode) - Sıcak Espresso & Gece Yeşili Uyumu
     ========================================================================== */
  :global(.dark) header {
    background: rgba(28, 26, 23, 0.85); /* Sıcak siyah/koyu kahve arkaplan */
    border-bottom: 1px solid rgba(56, 52, 48, 0.8);
    box-shadow: 0 4px 20px -10px rgba(0, 0, 0, 0.4);
  }

  :global(.dark) h2 a,
  :global(.dark) h2 a.active {
    color: #f3efe6; /* Sıcak kemik rengi */
  }

  :global(.dark) h2 a:hover {
    color: #86b090; /* Aydınlık adaçayı yeşili */
  }

  :global(.dark) nav a {
    color: #a8a29e;
  }

  :global(.dark) nav a:hover {
    color: #f3efe6;
    background-color: rgba(63, 59, 55, 0.4);
  }

  :global(.dark) nav a.active {
    color: #f3efe6;
    background-color: #262320;
  }

  :global(.dark) nav a.active::after {
    background-color: #86b090; /* Karanlık modda açık yeşil nokta */
  }

  /* ==========================================================================
     7. MOBİL UYUMLULUK
     ========================================================================== */
  @media (max-width: 720px) {
    header {
      padding: 0 1em;
    }
    nav {
      height: 60px;
    }
    nav a {
      padding: 0.4em 0.6em;
      font-size: 0.88em;
    }
  }
</style>
