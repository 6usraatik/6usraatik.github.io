---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="tr">
	<head>
		<BaseHead title={`Projelerim | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Sayfa Giriş Başlığı ve Tanımı -->
			<section class="intro-header">
				<h1>💻 Projelerim ve Çalışmalarım</h1>
				<p>
					Projelerimin özetlerini burada bulabilirsin. Kartlara tıklayarak teknik detaylara ve açık kaynak GitHub kodlarına ulaşabilirsin.
				</p>
				<hr />
			</section>

			<!-- Proje Kartları Grid Alanı -->
			<section class="projects-grid">
				<ul>
					{
						posts.map((post, index) => (
							<li style={`animation-delay: ${0.15 + index * 0.1}s;`}>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<div class="image-wrapper">
											<img width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
										</div>
									)}
									<div class="card-content">
										<span class="date-badge">
											<FormattedDate date={post.data.pubDate} />
										</span>
										<h4 class="title">{post.data.title}</h4>
										{post.data.description && (
											<p class="description">{post.data.description}</p>
										)}
										<div class="card-footer">
											<span class="read-more">Projeyi İncele & GitHub Linki ➔</span>
										</div>
									</div>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* ==========================================================================
	   ÖZEL RENK PALETİ VE DEĞİŞKENLER (Sıcak, Doğal ve Pastel Tonlar)
	   ========================================================================== */
	main {
		--text-main: #2c2926;         /* Derin espresso kahvesi */
		--text-muted: #645f5b;        /* Yumuşak toprak/kahve-gri */
		--accent-green: #597a61;      /* Adaçayı yeşili */
		--accent-blue: #4d6d88;       /* Pastel slate-mavi */
		--card-bg: #fcfbf9;           /* Çok hafif sıcak kemik/krem */
		--card-border: #e8e2d8;       /* Kum beji kenarlık */
		--card-hover-bg: #ffffff;
		--date-bg: #eff4ec;
		--date-text: #597a61;
		--shadow-soft: 0 12px 35px -10px rgba(115, 102, 90, 0.12);
		--shadow-hover: 0 18px 40px -12px rgba(89, 122, 97, 0.18);

		width: 960px;
		max-width: calc(100% - 2em);
		margin: 0 auto;
		padding: 3em 1em;
		color: var(--text-main);
	}

	/* ==========================================================================
	   GİRİŞ ALANI VE TİPOGRAFİ
	   ========================================================================== */
	.intro-header {
		text-align: left;
		margin-bottom: 2.5rem;
		animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}
	.intro-header h1 {
		font-size: 2.4rem;
		font-weight: 800;
		letter-spacing: -0.03em;
		color: var(--text-main);
		margin-bottom: 0.8rem;
	}
	.intro-header p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: var(--text-muted);
		max-width: 750px;
	}
	hr {
		border: none;
		height: 1px;
		background: linear-gradient(90deg, var(--card-border) 0%, transparent 100%);
		margin-top: 2rem;
	}

	/* ==========================================================================
	   PROJE KARTLARI GRİD TASARIMI (Modern, Organik Kıvrımlar)
	   ========================================================================== */
	ul {
		display: grid;
		grid-template-columns: repeat(2, 1fr); /* 2 Sütunlu şık grid layout */
		gap: 2rem;
		list-style-type: none;
		margin: 0;
		padding: 0;
	}

	li {
		opacity: 0;
		animation: fadeSlideUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
	}

	li a {
		display: flex;
		flex-direction: column;
		height: 100%;
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		border-radius: 16px;          /* Organik, yumuşak köşeler */
		overflow: hidden;
		text-decoration: none;
		transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
		box-shadow: var(--shadow-soft);
	}

	/* Kartın Üzerine Gelindiğinde (Hover Efekti) - Zarifçe yükselip pastel mavi/yeşil vurgu alması */
	li a:hover {
		transform: translateY(-6px);
		background: var(--card-hover-bg);
		border-color: var(--accent-green);
		box-shadow: var(--shadow-hover);
	}

	/* Görsel Alanı */
	.image-wrapper {
		width: 100%;
		height: 200px;
		overflow: hidden;
		background-color: #f3efe6;
		border-bottom: 1px solid var(--card-border);
	}
	.image-wrapper img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	li a:hover .image-wrapper img {
		transform: scale(1.04); /* Resmin içinde çok hafif zoom hissi */
	}

	/* Kart İçerik Alanı */
	.card-content {
		padding: 1.6rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}

	.date-badge {
		display: inline-block;
		background: var(--date-bg);
		color: var(--date-text);
		padding: 4px 12px;
		border-radius: 20px;
		font-size: 0.8em;
		font-weight: 600;
		margin-bottom: 0.8rem;
		width: fit-content;
	}

	.title {
		font-size: 1.35rem;
		font-weight: 700;
		color: var(--text-main);
		margin: 0 0 0.6rem 0;
		line-height: 1.3;
		transition: color 0.25s ease;
	}
	li a:hover .title {
		color: var(--accent-blue); /* Başlık hover durumda pastel maviye dönsün */
	}

	.description {
		font-size: 0.95rem;
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0 0 1.5rem 0;
		flex-grow: 1;
	}

	/* Kart Alt Buton İbaresi */
	.card-footer {
		border-top: 1px solid rgba(232, 226, 216, 0.6);
		padding-top: 1rem;
		margin-top: auto;
	}
	.read-more {
		font-size: 0.88rem;
		font-weight: 600;
		color: var(--accent-green);
		transition: transform 0.2s ease;
		display: inline-block;
	}
	li a:hover .read-more {
		transform: translateX(4px); /* Ok işareti hafifçe sağa kaysın */
	}

	/* ==========================================================================
	   ANİMASYONLAR
	   ========================================================================== */
	@keyframes fadeSlideUp {
		0% {
			opacity: 0;
			transform: translateY(28px);
		}
		100% {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* ==========================================================================
	   KARANLIK MOD (Dark Mode) - Sıcak Koyu Espresso & Adaçayı Uyumu
	   ========================================================================== */
	:global(.dark) main {
		--text-main: #f3efe6;
		--text-muted: #a8a29e;
		--accent-green: #86b090;
		--accent-blue: #648dae;
		--card-bg: #262320;
		--card-border: #383430;
		--card-hover-bg: #2d2925;
		--date-bg: rgba(89, 122, 97, 0.2);
		--date-text: #86b090;
		--shadow-soft: 0 12px 35px -10px rgba(0, 0, 0, 0.5);
		--shadow-hover: 0 18px 40px -12px rgba(0, 0, 0, 0.7);
	}
	:global(.dark) .card-footer {
		border-top-color: rgba(56, 52, 48, 0.8);
	}
	:global(.dark) .image-wrapper {
		background-color: #1e1b18;
	}

	/* ==========================================================================
	   MOBİL UYUMLULUK
	   ========================================================================== */
	@media (max-width: 768px) {
		ul {
			grid-template-columns: 1fr; /* Mobil ve küçük ekranda tek sütuna düşsün */
			gap: 1.5rem;
		}
		.intro-header h1 {
			font-size: 1.8rem;
		}
	}
</style>